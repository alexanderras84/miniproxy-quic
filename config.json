{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tcp-in",
      "listen": "::",
      "listen_port": 443,
      "network": "tcp",
      "sniff": true,
      "sniff_override_destination": true,
      "sniff_timeout": "300ms",
      "domain_strategy": "prefer_ipv4"
    },
    {
      "type": "tproxy",
      "tag": "udp-in",
      "listen": "::",
      "listen_port": 443,
      "network": "udp",
      "sniff": true,
      "sniff_override_destination": true,
      "sniff_timeout": "300ms",
      "udp_fragment": true
    },
    {
      "type": "tproxy",
      "tag": "http-in",
      "listen": "::",
      "listen_port": 80,
      "network": "tcp",
      "sniff": true,
      "sniff_override_destination": true,
      "sniff_timeout": "300ms"
    }
  ],

  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out"
    }
  ],

  "route": {
    "auto_detect_interface": true,

    "rules": [
      {
        "ip_cidr": [
          "127.0.0.0/8",
          "::1/128",
          "193.161.200.70/32",
          "2a11:fc0:0:a:250:56ff:fe9b:37a0/128"
        ],
        "outbound": "direct-out"
      }
    ]
  },

  "experimental": {
    "cache_file": {
      "enabled": false
    }
  },

  "socket": {
    "mark": 1
  }
}
